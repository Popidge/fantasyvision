# Copy this to .env.local for local development.
# For production, set VITE_* vars in Vercel dashboard and
# CLERK_JWT_ISSUER_DOMAIN via: npx convex env set CLERK_JWT_ISSUER_DOMAIN <value>

# Convex deployment URL (from convex dashboard or `convex deploy` output)
VITE_CONVEX_URL=https://<deployment>.convex.cloud

# Clerk publishable key (use test key for dev, live key for prod)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# --- Convex backend env vars (set via `npx convex env set`, NOT in Vercel) ---
# CLERK_JWT_ISSUER_DOMAIN=https://<your-clerk-domain>.clerk.accounts.dev
